from collections.abc import Callable, Mapping
from contextlib import AbstractContextManager
from dataclasses import dataclass
from datetime import UTC, datetime, timedelta
from uuid import UUID

from backend.db.models import (
    DeliveryAttemptModel,
    NotificationDeliveryModel,
)
from backend.db.unit_of_work import SqlAlchemyUnitOfWork
from backend.domain.enums import Channel, DeliveryOutcomeStatus, DeliveryStatus
from backend.domain.results import DeliveryOutcome, DeliveryWorkerResult
from workers.delivery.base import DeliveryAdapter

UnitOfWorkFactory = Callable[[], AbstractContextManager[SqlAlchemyUnitOfWork]]


@dataclass(frozen=True)
class ClaimedDelivery:
    delivery_id: UUID
    claim_token: UUID


class DeliveryWorker:
    def __init__(
        self,
        *,
        unit_of_work_factory: UnitOfWorkFactory,
        adapters: Mapping[Channel, DeliveryAdapter],
        channels: tuple[Channel, ...] | None = None,
        now: Callable[[], datetime],
        worker_id: str,
        lease_duration: timedelta,
        retry_delay: timedelta,
    ) -> None:
        self._unit_of_work_factory = unit_of_work_factory
        self._adapters = adapters
        self._channels = channels
        self._now = now
        self._worker_id = worker_id
        self._lease_duration = lease_duration
        self._retry_delay = retry_delay

    @property
    def channels(self) -> tuple[Channel, ...] | None:
        return self._channels

    def process_due_deliveries(self, *, limit: int) -> DeliveryWorkerResult:
        now = self._aware_utc_now()
        lease_expires_at = now + self._lease_duration

        with self._unit_of_work_factory() as uow:
            deliveries = uow.notifications.claim_due_deliveries(
                now=now,
                limit=limit,
                worker_id=self._worker_id,
                lease_expires_at=lease_expires_at,
                channels=self._channels,
            )
            claims = [
                ClaimedDelivery(delivery_id=delivery.id, claim_token=delivery.claim_token)
                for delivery in deliveries
                if delivery.claim_token is not None
            ]
            uow.commit()

        processed_count = 0
        for claim in claims:
            delivery = self._load_claimed_delivery_context(claim)
            if delivery is None:
                continue
            outcome = self._deliver(delivery)
            if self._finalize_claimed_delivery(
                claim=claim,
                outcome=outcome,
                now=now,
            ):
                processed_count += 1

        return DeliveryWorkerResult(
            claimed_count=len(claims),
            processed_count=processed_count,
        )

    def _load_claimed_delivery_context(
        self,
        claim: ClaimedDelivery,
    ) -> NotificationDeliveryModel | None:
        with self._unit_of_work_factory() as uow:
            return uow.notifications.get_claimed_delivery_context(
                delivery_id=claim.delivery_id,
                claim_token=claim.claim_token,
            )

    def _finalize_claimed_delivery(
        self,
        *,
        claim: ClaimedDelivery,
        outcome: DeliveryOutcome,
        now: datetime,
    ) -> bool:
        with self._unit_of_work_factory() as uow:
            delivery = uow.notifications.get_claimed_delivery_for_update(
                delivery_id=claim.delivery_id,
                claim_token=claim.claim_token,
            )
            if delivery is None:
                return False
            self._record_outcome(
                uow,
                delivery=delivery,
                outcome=outcome,
                now=now,
            )
            uow.commit()
            return True

    def _aware_utc_now(self) -> datetime:
        now = self._now()
        if now.tzinfo is None or now.utcoffset() is None:
            raise ValueError("now must be timezone-aware")
        return now.astimezone(UTC)

    def _deliver(self, delivery: NotificationDeliveryModel) -> DeliveryOutcome:
        try:
            channel = Channel(delivery.channel)
        except ValueError:
            return DeliveryOutcome(
                status=DeliveryOutcomeStatus.FAILED_TERMINAL,
                error_code="unsupported_channel",
                error_message=f"unsupported channel {delivery.channel}",
            )

        adapter = self._adapters.get(channel)
        if adapter is None:
            return DeliveryOutcome(
                status=DeliveryOutcomeStatus.FAILED_TERMINAL,
                error_code="missing_adapter",
                error_message=f"missing delivery adapter for {channel.value}",
            )

        return adapter.deliver(
            delivery=delivery,
            notification=delivery.notification,
            user=delivery.user,
        )

    def _record_outcome(
        self,
        uow: SqlAlchemyUnitOfWork,
        *,
        delivery: NotificationDeliveryModel,
        outcome: DeliveryOutcome,
        now: datetime,
    ) -> None:
        attempt_number = delivery.attempt_count + 1
        delivery.attempt_count = attempt_number

        final_status = self._final_status(
            outcome=outcome,
            attempt_count=attempt_number,
            max_attempts=delivery.max_attempts,
        )
        delivery.status = final_status.value
        delivery.provider_message_id = outcome.provider_message_id
        delivery.last_error_code = outcome.error_code
        delivery.last_error_message = outcome.error_message
        delivery.updated_at = now

        if final_status is DeliveryStatus.DELIVERED:
            delivery.delivered_at = now
            delivery.next_attempt_at = now
            delivery.last_error_code = None
            delivery.last_error_message = None
        elif final_status is DeliveryStatus.FAILED_RETRYABLE:
            delivery.next_attempt_at = now + self._retry_delay
        else:
            delivery.next_attempt_at = now

        delivery.processing_started_at = None
        delivery.lease_expires_at = None
        delivery.claimed_by = None

        uow.notifications.add_delivery_attempt(
            DeliveryAttemptModel(
                delivery_id=delivery.id,
                attempt_number=attempt_number,
                status=final_status.value,
                error_code=outcome.error_code,
                error_message=outcome.error_message,
                provider_message_id=outcome.provider_message_id,
                started_at=now,
                finished_at=now,
            )
        )

    def _final_status(
        self,
        *,
        outcome: DeliveryOutcome,
        attempt_count: int,
        max_attempts: int,
    ) -> DeliveryStatus:
        if outcome.status is DeliveryOutcomeStatus.DELIVERED:
            return DeliveryStatus.DELIVERED
        if outcome.status is DeliveryOutcomeStatus.FAILED_TERMINAL:
            return DeliveryStatus.FAILED_TERMINAL
        if attempt_count >= max_attempts:
            return DeliveryStatus.FAILED_TERMINAL
        return DeliveryStatus.FAILED_RETRYABLE
